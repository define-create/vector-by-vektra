// Vector by Vektra – Prisma Schema
// Provider: Supabase Postgres
// Runtime: pgBouncer (DATABASE_URL), Migrations: direct (DIRECT_URL)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  user
  admin
}

enum UserPlan {
  free
  pro
}

enum TrustTier {
  unverified
  verified_email
}

enum DataSource {
  manual
  future_scraped
}

enum RatingRunType {
  nightly
  admin
}

enum RatingRunStatus {
  running
  succeeded
  failed
}

enum AuditActionType {
  void_match
  edit_match
  merge_player
  edit_player_identity
  claim_profile
  trigger_recompute
  rename_tag
  delete_player
  unclaim_profile
  send_invite
  claim_via_invite
}

enum AuditEntityType {
  Match
  Player
  RatingRun
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id                           String    @id @default(cuid())
  email                        String    @unique
  emailVerifiedAt              DateTime?
  emailVerificationToken       String?   @unique
  emailVerificationTokenExpiry DateTime?
  passwordResetToken           String?
  passwordResetTokenExpiresAt  DateTime?
  handle                       String    @unique
  displayName                  String
  passwordHash                 String
  role                         UserRole  @default(user)
  plan                         UserPlan  @default(free)
  createdAt                    DateTime  @default(now())

  // Relations
  player          Player?
  enteredMatches  Match[]
  auditEvents     AuditEvent[]
  matchupShares   MatchupShare[]
  invitesSent     InviteToken[]  @relation("InvitesSent")
  invitesClaimed  InviteToken[]  @relation("InvitesClaimed")
}

// ---------------------------------------------------------------------------
// Players (shadow profile = userId null)
// ---------------------------------------------------------------------------

model Player {
  id               String     @id @default(cuid())
  userId           String?    @unique
  displayName      String
  claimed          Boolean    @default(false)
  claimedAt        DateTime?
  trustTier        TrustTier  @default(unverified)
  rating           Float      @default(1000)
  ratingConfidence Float      @default(0)
  ratingVolatility Float      @default(0)
  winPct            Float?
  optOutPredictions Boolean    @default(false)
  createdAt         DateTime   @default(now())
  deletedAt        DateTime?

  // Relations
  user             User?              @relation(fields: [userId], references: [id])
  matchParticipants MatchParticipant[]
  ratingSnapshots  RatingSnapshot[]
  inviteTokens     InviteToken[]

  @@index([displayName, deletedAt])
}

// ---------------------------------------------------------------------------
// Matches
// ---------------------------------------------------------------------------

model Match {
  id              String      @id @default(cuid())
  enteredByUserId String
  matchDate       DateTime
  tag             String?     // optional event/league label, free-text
  lockedAt        DateTime?
  voidedAt        DateTime?
  flaggedAt       DateTime?   // set when anomaly threshold is exceeded
  flagReason      String?     // e.g. "anomaly:high_volume"
  fingerprint     String?
  replacesMatchId String?     // set when this match was created by an admin edit (points to the voided original)
  dataSource      DataSource  @default(manual)
  createdAt       DateTime    @default(now())

  // Relations
  enteredBy       User              @relation(fields: [enteredByUserId], references: [id])
  participants    MatchParticipant[]
  games           Game[]
  ratingSnapshots RatingSnapshot[]

  @@index([voidedAt, matchDate])
  @@index([tag, voidedAt])
}

// ---------------------------------------------------------------------------
// MatchParticipants
// ---------------------------------------------------------------------------

model MatchParticipant {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     Int    // 1 or 2

  // Relations
  match    Match  @relation(fields: [matchId], references: [id])
  player   Player @relation(fields: [playerId], references: [id])

  @@index([playerId])
}

// ---------------------------------------------------------------------------
// Games (individual games within a match)
// ---------------------------------------------------------------------------

model Game {
  id         String @id @default(cuid())
  matchId    String
  gameOrder  Int
  team1Score Int
  team2Score Int

  // Relations
  match      Match  @relation(fields: [matchId], references: [id])
}

// ---------------------------------------------------------------------------
// RatingRuns (batch recompute runs)
// ---------------------------------------------------------------------------

model RatingRun {
  id          String          @id @default(cuid())
  runType     RatingRunType
  startedAt   DateTime        @default(now())
  finishedAt  DateTime?
  status      RatingRunStatus @default(running)
  notes       String?         // max 120 chars enforced at API layer
  replayScope String          @default("full")  // "full" | "incremental"
  fromMatchId String?         // earliest match replayed (incremental runs only)

  // Relations
  snapshots   RatingSnapshot[]

  @@index([status, startedAt])
}

// ---------------------------------------------------------------------------
// RatingSnapshots (per-match rating history — immutable after write)
// ---------------------------------------------------------------------------

model RatingSnapshot {
  id            String   @id @default(cuid())
  runId         String
  playerId      String
  matchId       String
  matchDate     DateTime
  rating        Float
  effectiveK    Float
  expectedScore Float

  // Relations
  run           RatingRun @relation(fields: [runId], references: [id])
  player        Player    @relation(fields: [playerId], references: [id])
  match         Match     @relation(fields: [matchId], references: [id])

  @@index([playerId, matchId])
}

// ---------------------------------------------------------------------------
// AuditEvents (immutable — never update, never delete)
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// CommunityStats (singleton row, id=1 — populated by recompute)
// ---------------------------------------------------------------------------

model CommunityStats {
  id         Int      @id @default(1)
  avgRating  Float
  minRating  Float
  maxRating  Float
  totalCount Int
  updatedAt  DateTime @updatedAt
}

model AuditEvent {
  id           String          @id @default(cuid())
  entityType   AuditEntityType
  entityId     String
  actionType   AuditActionType
  adminUserId  String?
  metadata     Json?
  createdAt    DateTime        @default(now())

  // Relations
  admin        User?           @relation(fields: [adminUserId], references: [id])
}

// ---------------------------------------------------------------------------
// MatchupShare (shareable prediction card snapshots)
// ---------------------------------------------------------------------------

model MatchupShare {
  id              String    @id @default(cuid())
  tokenHash       String    @unique
  createdByUserId String
  snapshotJson    Json
  createdAt       DateTime  @default(now())
  expiresAt       DateTime?
  viewCount       Int       @default(0)

  // Relations
  createdBy       User      @relation(fields: [createdByUserId], references: [id])
}

// ---------------------------------------------------------------------------
// InviteToken (friend invite to claim a shadow profile)
// ---------------------------------------------------------------------------

model InviteToken {
  id              String    @id @default(cuid())
  tokenHash       String    @unique
  playerId        String
  invitedByUserId String
  invitedEmail    String?
  expiresAt       DateTime
  claimedAt       DateTime?
  claimedByUserId String?
  createdAt       DateTime  @default(now())

  // Relations
  player          Player    @relation(fields: [playerId], references: [id])
  invitedBy       User      @relation("InvitesSent", fields: [invitedByUserId], references: [id])
  claimedBy       User?     @relation("InvitesClaimed", fields: [claimedByUserId], references: [id])

  @@index([playerId])
}
