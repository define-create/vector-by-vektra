// Vector by Vektra – Prisma Schema
// Provider: Supabase Postgres
// Runtime: pgBouncer (DATABASE_URL), Migrations: direct (DIRECT_URL)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  user
  admin
}

enum UserPlan {
  free
  pro
}

enum TrustTier {
  unverified
  verified_email
  established
}

enum DataSource {
  manual
  future_scraped
}

enum RatingRunType {
  nightly
  admin
}

enum RatingRunStatus {
  running
  succeeded
  failed
}

enum AuditActionType {
  void_match
  merge_player
  edit_player_identity
  claim_profile
  trigger_recompute
}

enum AuditEntityType {
  Match
  Player
  RatingRun
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?
  handle          String    @unique
  displayName     String
  passwordHash    String
  role            UserRole  @default(user)
  plan            UserPlan  @default(free)
  createdAt       DateTime  @default(now())

  // Relations
  player          Player?
  enteredMatches  Match[]
  auditEvents     AuditEvent[]
}

// ---------------------------------------------------------------------------
// Players (shadow profile = userId null)
// ---------------------------------------------------------------------------

model Player {
  id               String     @id @default(cuid())
  userId           String?    @unique
  displayName      String
  claimed          Boolean    @default(false)
  claimedAt        DateTime?
  trustTier        TrustTier  @default(unverified)
  rating           Float      @default(1000)
  ratingConfidence Float      @default(0)
  ratingVolatility Float      @default(0)
  createdAt        DateTime   @default(now())
  deletedAt        DateTime?

  // Relations
  user             User?              @relation(fields: [userId], references: [id])
  matchParticipants MatchParticipant[]
  ratingSnapshots  RatingSnapshot[]
}

// ---------------------------------------------------------------------------
// Matches
// ---------------------------------------------------------------------------

model Match {
  id              String      @id @default(cuid())
  enteredByUserId String
  matchDate       DateTime
  lockedAt        DateTime?
  voidedAt        DateTime?
  dataSource      DataSource  @default(manual)
  createdAt       DateTime    @default(now())

  // Relations
  enteredBy       User              @relation(fields: [enteredByUserId], references: [id])
  participants    MatchParticipant[]
  games           Game[]
  ratingSnapshots RatingSnapshot[]
}

// ---------------------------------------------------------------------------
// MatchParticipants
// ---------------------------------------------------------------------------

model MatchParticipant {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     Int    // 1 or 2

  // Relations
  match    Match  @relation(fields: [matchId], references: [id])
  player   Player @relation(fields: [playerId], references: [id])
}

// ---------------------------------------------------------------------------
// Games (individual games within a match)
// ---------------------------------------------------------------------------

model Game {
  id         String @id @default(cuid())
  matchId    String
  gameOrder  Int
  team1Score Int
  team2Score Int

  // Relations
  match      Match  @relation(fields: [matchId], references: [id])
}

// ---------------------------------------------------------------------------
// RatingRuns (batch recompute runs)
// ---------------------------------------------------------------------------

model RatingRun {
  id         String          @id @default(cuid())
  runType    RatingRunType
  startedAt  DateTime        @default(now())
  finishedAt DateTime?
  status     RatingRunStatus @default(running)
  notes      String?         // max 120 chars enforced at API layer

  // Relations
  snapshots  RatingSnapshot[]
}

// ---------------------------------------------------------------------------
// RatingSnapshots (per-match rating history — immutable after write)
// ---------------------------------------------------------------------------

model RatingSnapshot {
  id            String   @id @default(cuid())
  runId         String
  playerId      String
  matchId       String
  matchDate     DateTime
  rating        Float
  effectiveK    Float
  expectedScore Float

  // Relations
  run           RatingRun @relation(fields: [runId], references: [id])
  player        Player    @relation(fields: [playerId], references: [id])
  match         Match     @relation(fields: [matchId], references: [id])
}

// ---------------------------------------------------------------------------
// AuditEvents (immutable — never update, never delete)
// ---------------------------------------------------------------------------

model AuditEvent {
  id           String          @id @default(cuid())
  entityType   AuditEntityType
  entityId     String
  actionType   AuditActionType
  adminUserId  String?
  metadata     Json?
  createdAt    DateTime        @default(now())

  // Relations
  admin        User?           @relation(fields: [adminUserId], references: [id])
}
